# Prism Healthcare Platform — Production Environment
# Copy to /home/prism/app/.env.production and fill in all CHANGE_ME values

# ── Domain ──────────────────────────────────────────────────
DOMAIN=CHANGE_ME

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=healthcare_federation
POSTGRES_USER=prism_user
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# ── JWT ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME

# ── SMTP (email verification) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
FROM_EMAIL=noreply@CHANGE_ME

# ── Anthropic (optional — audio transcription NLU) ─────────
ANTHROPIC_API_KEY=

# ── Epic FHIR (optional — disabled by default) ─────────────
EPIC_AUTH_ENABLED=false
EPIC_BASE_URL=
EPIC_CLIENT_ID=
EPIC_PRIVATE_KEY=

# ── ML services (disabled — Node wrappers degrade gracefully)
CARE_PLAN_PARSER_URL=
FEATURE_EXTRACTION_URL=
